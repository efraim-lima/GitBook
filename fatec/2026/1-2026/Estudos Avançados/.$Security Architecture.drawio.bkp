        <mxCell id="qBCxrTD1t-5IboGwivxb-18" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Kubernetes -&amp;gt; Docker&lt;/h1&gt;&lt;p&gt;Implementar virtualização para serviços específicos, aplicações de uso interno/externo, organização dos ambientes de desenvolvimento e de produção.&lt;br&gt;&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-74" y="105" width="332.07565279490217" height="103.08472460248099" as="geometry" />
        </mxCell>
        <mxCell id="qBCxrTD1t-5IboGwivxb-19" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;p style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;Proteção:&lt;br&gt;- servidores guest devidamente hardenizados&amp;nbsp;&lt;br&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- portas abertas estritamente necessárias,&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- serviços rodando apenas sendo os necessários,&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-74" y="183.44" width="208" height="147.56" as="geometry" />
        </mxCell>
        <mxCell id="qBCxrTD1t-5IboGwivxb-20" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;p style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;não permitir root over ssh&lt;br&gt;- acesso remoto apenas criptografado e com par de chaves, &lt;br&gt;- containers em redes apartadas&lt;br&gt;- configuração de redundância nos Pods para balanceamento de carga&lt;/span&gt;&lt;/p&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="134" y="193" width="208" height="144.56" as="geometry" />
        </mxCell>
        <mxCell id="qBCxrTD1t-5IboGwivxb-22" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;p style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;- RBAC -&amp;gt; com foco em permitir autenticação dos usuários ao sistema,&lt;br&gt;- VPN -&amp;gt; para tunelar o tráfego externo e garantir&amp;nbsp;&lt;/p&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">

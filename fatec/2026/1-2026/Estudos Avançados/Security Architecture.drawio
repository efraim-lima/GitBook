        <mxCell id="Jj2LBuBIAdHEPYUArqaq-9" parent="Jj2LBuBIAdHEPYUArqaq-5" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;NG Firewall&lt;/h1&gt;&lt;p&gt;Implementar um NG Firewall para bloquear acessos dos usuários indevidos no ambiente&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="122.22" width="327.5" x="269.5" y="76.78" as="geometry" />

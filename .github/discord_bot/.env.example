# 1. DISCORD_TOKEN
#    Your bot token from https://discord.com/developers/applications
#    → Your App > Bot > Token > Reset Token
DISCORD_TOKEN=

# 2. AUTHORIZED_USER_IDS
#    Comma-separated Discord User IDs allowed to issue `delegate` commands.
#    How to get an ID:
#      Discord → Settings → Advanced → enable Developer Mode
#      Right-click any user → Copy User ID
#    Example: 123456789012345678,987654321098765432
AUTHORIZED_USER_IDS=

# 3. AGENTS_DIR
#    Absolute path to the directory that contains the agent .py files.
#    Each agent must exist as <agent_id>.py inside this directory.
AGENTS_DIR=..
# ^ relative to discord_bot/ — resolves to .github/

# 4. PYTHON_EXECUTABLE  (optional)
#    Full path to the Python interpreter used to run agent scripts.
#    Leave blank to reuse the same interpreter that runs the bot.
PYTHON_EXECUTABLE=/usr/bin/python3

# 5. REPLY_TIMEOUT_SECONDS  (optional, default 120)
#    Seconds the bot waits for a user reply to an agent QUESTION before
#    sending an empty response and continuing.
REPLY_TIMEOUT_SECONDS=120

# 6. MAX_MESSAGE_LENGTH  (optional, default 1900)
#    Maximum characters per Discord message chunk.
#    Discord hard limit is 2000; keep this at ≤ 1900 for safety.
MAX_MESSAGE_LENGTH=1900

# 7. STARTUP_CHANNEL_ID  (optional)
#    Discord channel ID where the bot announces it is online on startup.
#    Enable Developer Mode → right-click channel → Copy Channel ID.
STARTUP_CHANNEL_ID=

# 8. GITHUB_TOKEN  (required for alfred.py)
#    GitHub personal access token with read access.
#    Used to call GitHub Models API (gpt-4o-mini by default).
#    https://github.com/settings/tokens  →  Fine-grained or classic PAT
GITHUB_TOKEN=

# 9. ALFRED_MODEL  (optional, default gpt-4o-mini)
#    GitHub Models model name used by alfred.py.
#    Available: gpt-4o, gpt-4o-mini, Phi-4, Mistral-large-2407 …
ALFRED_MODEL=

# 10. CHORD_PREFIX  (optional, default "EM7 FM7 Am7")
#     Chord sequence that must begin every reply to an active agent session.
#     Change only if you want a different secret prefix.
CHORD_PREFIX=EM7 FM7 Am7
─────────────────────────────────────────────────────────────────────────────
# Discord Bot — Environment Configuration
# Fill in your values below, then save.  Do NOT commit this file to git.
# ─────────────────────────────────────────────────────────────────────────────
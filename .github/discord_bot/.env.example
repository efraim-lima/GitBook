# ── Discord ────────────────────────────────────────────────────────────────────
# Token do bot Discord (obrigatório)
DISCORD_TOKEN=your-bot-token-here

# IDs dos usuários autorizados a enviar comandos ao bot (separados por vírgula)
AUTHORIZED_USER_IDS=123456789012345678,987654321098765432

# ── Canais ─────────────────────────────────────────────────────────────────────
# ID do canal onde o bot envia mensagem ao inicializar (opcional)
STARTUP_CHANNEL_ID=123456789012345678

# ── Agentes ────────────────────────────────────────────────────────────────────
# Caminho para o diretório de agentes (relativo à pasta do bot ou absoluto)
AGENTS_DIR=..

# Executável Python usado para rodar os agentes (usa o Python do ambiente se omitido)
PYTHON_EXECUTABLE=/usr/bin/python3

# ── Workspace ──────────────────────────────────────────────────────────────────
# Diretório raiz do workspace GitBook
WORKSPACE_ROOT=/path/to/your/GitBook

# ── Segurança de sessão ────────────────────────────────────────────────────────
# Prefixo exigido nas respostas de sessões ativas (chord prefix)
CHORD_PREFIX=EM7 FM7 Am7

# ── Comportamento ──────────────────────────────────────────────────────────────
# Timeout (em segundos) para aguardar respostas em sessões ativas
REPLY_TIMEOUT_SECONDS=120

# Tamanho máximo de uma mensagem Discord (em caracteres)
MAX_MESSAGE_LENGTH=1900
